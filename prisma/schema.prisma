// Itinera data model — a clean rebuild of the v1 schema.
// A "Trip" is a shared travel workspace: itinerary, files, discussion, votes.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  // Postgres for prod/dev. For a zero-setup local start you can switch
  // provider to "sqlite" and DATABASE_URL to "file:./dev.db".
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Visibility {
  PUBLIC
  PRIVATE
}

enum MemberRole {
  OWNER
  MEMBER
}

enum RequestStatus {
  PENDING
  APPROVED
  REJECTED
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  createdAt     DateTime  @default(now())

  profile      Profile?
  ownedTrips   Trip[]         @relation("TripOwner")
  memberships  Membership[]
  votes        Vote[]
  comments     Comment[]
  files        File[]
  joinRequests JoinRequest[]

  // Auth.js
  accounts Account[]
  sessions Session[]
}

// ---- Auth.js (NextAuth) models ----

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Profile {
  id          String  @id @default(cuid())
  userId      String  @unique
  user        User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  bio         String?
  location    String?
  interests   String? // comma-separated for now; can normalize later
}

model Trip {
  id          String     @id @default(cuid())
  title       String
  description String
  destination String?
  coverImage  String?
  startDate   DateTime?
  endDate     DateTime?
  visibility  Visibility @default(PUBLIC)
  votes       Int        @default(0) // denormalized score for fast sorting
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  ownerId String
  owner   User   @relation("TripOwner", fields: [ownerId], references: [id], onDelete: Cascade)

  memberships     Membership[]
  itineraryItems  ItineraryItem[]
  voteRecords     Vote[]
  comments        Comment[]
  files           File[]
  joinRequests    JoinRequest[]

  @@index([visibility, votes])
}

model Membership {
  id     String     @id @default(cuid())
  role   MemberRole @default(MEMBER)
  tripId String
  userId String
  trip   Trip       @relation(fields: [tripId], references: [id], onDelete: Cascade)
  user   User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([tripId, userId])
}

model ItineraryItem {
  id       String    @id @default(cuid())
  tripId   String
  trip     Trip      @relation(fields: [tripId], references: [id], onDelete: Cascade)
  dayIndex Int       @default(1)
  title    String
  place    String?
  notes    String?
  time     String?
  lat      Float?
  lng      Float?
  order    Int       @default(0)

  @@index([tripId, dayIndex, order])
}

model Vote {
  id       String @id @default(cuid())
  tripId   String
  userId   String
  value    Int    @default(1) // +1 upvote, -1 downvote
  trip     Trip   @relation(fields: [tripId], references: [id], onDelete: Cascade)
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([tripId, userId])
}

model Comment {
  id        String   @id @default(cuid())
  tripId    String
  authorId  String
  content   String
  createdAt DateTime @default(now())
  trip      Trip     @relation(fields: [tripId], references: [id], onDelete: Cascade)
  author    User     @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@index([tripId, createdAt])
}

model File {
  id          String   @id @default(cuid())
  tripId      String
  authorId    String
  url         String
  title       String
  description String?
  mimeType    String?
  keywords    String?
  createdAt   DateTime @default(now())
  trip        Trip     @relation(fields: [tripId], references: [id], onDelete: Cascade)
  author      User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
}

model JoinRequest {
  id        String        @id @default(cuid())
  tripId    String
  userId    String
  status    RequestStatus @default(PENDING)
  createdAt DateTime      @default(now())
  trip      Trip          @relation(fields: [tripId], references: [id], onDelete: Cascade)
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([tripId, userId])
}
