# Copy this file to .env.local and fill in real values. NEVER commit .env.local

# --- Database (Phase 1) ---
# Local Postgres or a free Neon/Supabase connection string.
# For quick local dev you can also point Prisma at SQLite (see prisma/schema.prisma).
DATABASE_URL="postgresql://user:password@localhost:5432/itinera?schema=public"

# --- Auth.js / NextAuth (Phase 1) ---
# Generate one with: openssl rand -base64 32
AUTH_SECRET=""

# Google OAuth (create at https://console.cloud.google.com)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# --- App ---
NEXT_PUBLIC_APP_URL="http://localhost:3000"
